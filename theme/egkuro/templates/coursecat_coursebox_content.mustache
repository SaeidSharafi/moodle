<div class="position-relative course-card">

    <a href="{{url}}">
    <h3 class="title text-center mb-0 py-1"> {{ name }} </h3>
    {{#images}}
       <div class="course-image">
        <img src="{{ image_url }}" class="w-100"/>
       </div>
    {{/images}}
    </a>
    <div class="position-absolute contact w-100 py-1 px-2">
    <p class="contact-teachers-label mb-0 py1"> {{ contact_string }}: </p>
    {{#contacts}}
        <div class="d-flex flex-aling-items-start" style="flex-shrink:0;">

        <a href="{{ url }}" class="contact-teacher">
        <i class="icon fa fa-comments fa-fw "></i> {{ name }}
         </a>
        </div>
    {{/contacts}}
    </div>
</div>
