{{!
    @template format_vums/list_all_sections


    Example context (json):
    {
        "generalsection": "1/0",
        "sections": "1/0",
        "editing": "1/0",
        "addsection": "addsection",
        "addnewactivity": "1/0",
        "leftnav": "1/0",
        "rightnav": "1/0",
        "courseid": "courseid"
        "user_id": "user_id"
        "defaultview": "defaultview"
        "index": "index"
    }
}}
{{#editing}}
<div id="card-editing-container" class="vums-format-card all-section-format theme-{{theme}} row">
    <ul class="sections row generalsection-container">
        {{! Display General Section }}
        {{#generalsection}}
        {{> format_vums/card_general_section_edit }}
        {{/generalsection}}
    </ul>
</div>

<div id="list-editing-container" class="vums-format-list all-section-format all-section theme-{{theme}} mt-20">
    <ul class="nav nav-tabs nav-fill" role="tablist">
        {{#sections}}
            {{> format_vums/list_sections_titles }}
        {{/sections}}
    </ul>
    <div  class="tab-content">
        {{#sections}}
            {{> format_vums/list_sections }}
        {{/sections}}
    </div>
</div>
{{/editing}}
{{^editing}}
<div id="card-container" class="vums-format-card all-section-format theme-{{theme}} row">
  <ul class="sections row generalsection-container">
      {{! Display General Section }}
      {{#generalsection}}
      {{> format_vums/card_general_section }}
      {{/generalsection}}
  </ul>
</div>
<div id="list-container" class="vums-format-list all-section-format theme-{{theme}} mt-20">
    <ul class="nav nav-tabs nav-fill" role="tablist">
        {{! Display Remaining Section }}
        {{#sections}}
            {{> format_vums/list_sections_titles }}
        {{/sections}}
    </ul>
    <div  class="tab-content">
        {{#sections}}
            {{> format_vums/list_sections }}
        {{/sections}}
    </div>
</div>

{{/editing}}

