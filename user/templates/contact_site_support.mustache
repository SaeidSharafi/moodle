{{!
    @template core_user/contact_site_support_email_body

    Support email email body.

    Example context (json):
    {
        "subject": "email subject",
        "notloggedinuser": true,
        "name": "Sender name",
        "email": "sender@mail.com",
        "description": "Support request message"
    }
}}
<div class="container">
    <div class="w-100">
        <div class="w-100 mx-auto rounded overflow-hidden" style="max-width: 400px">
            <img src="{{config.wwwroot}}/theme/moove/pix/helpDesk.jpg" class="w-100" alt="Contact-Us">
        </div>
    </div>
    <div id="support" class="mt-3 text-justify" style="line-height: 1.75rem; font-size: 14px;"></div>
</div>
